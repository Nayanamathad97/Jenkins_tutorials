pipeline {
    agent any
    
    options {
        ansiColor('xterm')
        disableConcurrentBuilds(abortPrevious : true)
        buildDiscarder(logRotator(numToKeepStr: '2'))
        disableResume()
        timeout(time: 2, units: 'MINUTES')
    }

    stages {
        stage('STAGE1') {
            steps {
                echo "\033[31mPreetham"
                sh 'pwd'
            }
        }
    }
}