pipeline {
    agent any
    stages {
        stage('STAGE1') {   
            when {
                expression { env.BRANCH_NAME == 'main' }
            }     
            steps {
                echo "running in branch"
                sh 'pwd'
            }
        }
        stage('STAGE1') {   
            when {
                expression { env.BRANCH_NAME == 'new_branch' }
            }     
            steps {
                echo "running in new_branch"
                sh 'pwd'
            }
        }
    }
}