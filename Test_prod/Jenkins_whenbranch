pipeline {
    agent any
    stages {
        stage('STAGE1') {   
            when {
                branch 'main' 
            }                
            steps {
                echo "running in branch"
                sh 'pwd'
            }
        }
        stage('STAGE2') {   
            when {
                branch 'new_branch' 
            }     
            steps {
                echo "running in new_branch"
                sh 'pwd'
            }
        }
        stage('DEBUG') {
            steps {
                echo "Current branch is: ${env.BRANCH_NAME}"
            }
        }
    }
}
