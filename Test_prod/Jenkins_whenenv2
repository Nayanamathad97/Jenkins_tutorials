pipeline {
    agent none

    triggers {
        cron(H/2 * * * *)
    }

    environment {
        live_env = 'test'
    }

    stages {
        stage('STAGE1') {
            when {
                environment name: 'live_env', value: 'test'
            }
            steps {
                echo "successfully ran in test"
                sh 'pwd'
            }
        }
    }
}