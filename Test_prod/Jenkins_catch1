pipeline {
    agent none
    stages {
        stage('STAGE1') {
            agent {label 'slave1'}
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    sh '''
                    pwd
                    sleep 5
                    '''                   
                }
            }
        }
        stage('PARALLEL STAGING') {            
            parallel {
                stage('STAGE3') {
                    agent {label 'slave2'}
                    steps {
                        echo "running parallel stage1"
                        sh '''
                        pwd
                        ls -ltr
                        '''
                    }
                }
                stage('STAGE4') {
                    agent {label 'slave2'}
                    steps {
                        echo "running parallel satge 4"
                        sh 'pwd'                 
        
                    }
                }
            }
        }
    }
}