pipeline {
    agent any
    parameters {
        booleanParam(name:'DEPLOY' , description:'want to deploy to production')
    }
    environment {
        CURRENT_ENV = 'prod'
    }
    stages {
        stage('CHECKOUT REPOA') {
            steps {
                checkout ([ $class: 'GitSCM',
                    branches: [[name: '*/main']], 
                    extensions: [], 
                    userRemoteConfigs: [[
                        credentialsId: 'nayanamathad97@gmail.com', 
                        url: 'https://github.com/Nayanamathad97/Jenkins_practice.git'
                    ]]
                ])
                        sh '''
                        echo GIT_BRANCH : $GIT_BRANCH
                        echo BRANCH_NAME : $BRANCH_NAME
                        '''
            }
        }
        stage('STAGE1 when branch main') {
            when {
                expression {return env.GIT_BRANCH == 'origin/main'}
            }
            steps {
                echo "Stage1 running"
                sh '''
                pwd
                ls -lrt
                '''
            }   
        }
        stage('when environment') {
            when {
                environment name: 'CURRENT_ENV', value : 'prod'
            }
            steps {
                echo "Stage2 running"
                sh '''
                pwd
                sleep 5
                '''
            }
        }
        stage('when parameter') {
            when {
                expression {Params.deploy == true}
            }
            steps {
                echo "This is final"
                sh '''
                pwd
                sleep 3
                '''
            }
        }
    }    
}