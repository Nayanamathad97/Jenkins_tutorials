pipeline {
    agent any
    parameters {
        string(name:'NAME', defaultValue:'', description:'enter the name')
        booleanParam(name:SKIP_TEST, description:'skip to run direct deployment')
        choice(name:'SELECT', choices:['dev','test','stagging'], description:'select one')
    }
    stages {
        stage('STAGE1') {
            steps {
                echo "NAME: ${params.NAME}"
                echo "SKIP_TEST: ${params.SKIP_TEST}"
                echo "SELECT: ${params.SELECT}"
                sh '''
                NAME: ${NAME}
                SKIP_TEST: ${SKIP_TEST}
                SELECT: ${SELECT}
                '''
            }
        }
    }
}