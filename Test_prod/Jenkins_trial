pipeline {
    agent none
    parameters {
        string(name:'NAME', defaultValue:'',description:'')
        booleanParam(name:'SKIP_TEST', description:'want to skip_test')
        choice(name:'SELECT', choices:['One','Two','Three'], description:'select one option')
    }
    stages {
        stage('STAGE1') {
            agent {label 'slave2'}
            steps {
                echo "name : ${params.NAME}"
                echo "SKIP_TEST : ${params.SKIP_TEST}"
                echo "SELECT : ${params.SELECT}"
                sh '''
                echo NAME: ${NAME}
                echo SKIP_TEST: ${SKIP_TEST}
                echo SELECT: ${SELECT}
                '''
            }
        }
    }
}