pipeline {
    agent any
    stages {
        stage('STAGE1_a') {
            steps {
                catchError('buildResult':'SUCCESS','stageResult':'FAILURE') {
                    echo "this is stage1_a"
                    sh '''
                        sleep 3
                        exit 1
                    '''
                }
            }
        }
        stage('STAGE1_b') {
            steps {
                script {
                    try {
                        sh ''' 
                            sleep 2
                            exit 1'''
                    }
                    catch (err) {
                        echo "error caught: ${err}"
                        currentBuild.result = 'SUCCESS'
                    }
                }
            }
        }
        stage('PARALLEL TESTING') {
            parallel {
                stage('WINDOWS TESTING') {
                    steps {
                        echo "WT"
                        sh 'sleep 2'
                    }                   
                }
                stage('MACOS TESTING') {
                    steps {
                        echo "MT"
                        sh 'sleep 2'
                    }                    
                }
            }
        }
        stage('FINAL') {
            steps {
                echo "Finale"
            }
        }
    }
}